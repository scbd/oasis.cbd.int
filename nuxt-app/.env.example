# External API host (required)
API_HOST=https://api.cbddev.xyz

# Accounts service URL (required)
ACCOUNTS_URL=https://accounts.cbddev.xyz

# Encryption password for signed URLs (required)
ENCRYPTION_PASSWORD=

# Translation API host — the existing Express server (default: local port 2012)
TRANSLATION_API_HOST=http://localhost:2012

# Dev server port (optional, default 3000)
# PORT=3000
